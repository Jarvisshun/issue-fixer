# Issue Fixer Configuration
# Copy this file to .env and fill in your values

# === Required ===

# GitHub Personal Access Token (with 'repo' scope)
# Get one at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxx

# === LLM Provider ===
# Choose ONE of the following options:

# Option 1: OpenAI-compatible API (default)
# Works with: OpenAI, DeepSeek, MiMo, Moonshot, GLM, etc.
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# Option 2: Local model via Ollama (no API key needed)
# Install Ollama: https://ollama.com
# Pull a model: ollama pull qwen2.5-coder:7b
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5-coder:7b

# === Optional ===

# GitHub Webhook Secret (optional, for webhook endpoint security)
# Set this to the same value you configure in GitHub webhook settings
# GITHUB_WEBHOOK_SECRET=your-webhook-secret
